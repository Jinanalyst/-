<%- include('partials/head') %>
<div class="profile-head">
  <div>
    <h1><%= seller.nickname %>님의 상점</h1>
    <% if (seller.area) { %><div class="muted small">📍 <%= seller.area %></div><% } %>
    <div class="muted small">가입일 <%= seller.created_at %></div>
  </div>
  <% if (user && user.id !== seller.id) { %>
    <a href="/messages/<%= seller.id %>" class="btn btn-primary">💬 쪽지 보내기</a>
  <% } %>
</div>

<h2 class="sec">판매 매물 (<%= listings.length %>)</h2>
<% if (listings.length===0) { %><p class="empty">등록된 매물이 없습니다.</p><% } else { %>
<div class="grid">
  <% listings.forEach(l=>{ %>
    <a class="card" href="/listings/<%= l.id %>">
      <div class="card-thumb">
        <% if (l.thumb) { %><img src="/uploads/<%= l.thumb %>"><% } else { %><div class="noimg">이미지 없음</div><% } %>
        <span class="status status-<%= l.status %>"><%= l.status %></span>
      </div>
      <div class="card-body">
        <div class="ttl"><%= l.title %></div>
        <div class="price"><%= won(l.price) %></div>
      </div>
    </a>
  <% }) %>
</div>
<% } %>
<%- include('partials/foot') %>
