<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> · 자취마켓</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script>window.__BLOB__ = <%= blobEnabled ? 'true' : 'false' %>;</script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
</head>
<body>
<header class="site-header">
  <div class="wrap header-inner">
    <a href="/" class="logo">🏠 자취마켓</a>
    <form class="searchbar" action="/" method="get">
      <input type="text" name="q" placeholder="원하는 자취용품을 검색하세요" value="<%= (query && query.q) || '' %>">
      <button type="submit">검색</button>
    </form>
    <nav class="topnav">
      <a href="/map">🗺️ 지도</a>
      <% if (user) { %>
        <a href="/messages" class="msg-link">쪽지<% if (unread>0){ %><span class="badge"><%= unread %></span><% } %></a>
        <a href="/mypage">마이</a>
        <a href="/listings/new" class="btn btn-primary btn-sm">+ 판매하기</a>
        <form action="/logout" method="post" class="inline"><button class="linkbtn"><%= user.nickname %> ▾ 로그아웃</button></form>
      <% } else { %>
        <a href="/login">로그인</a>
        <a href="/signup" class="btn btn-primary btn-sm">회원가입</a>
      <% } %>
    </nav>
  </div>
</header>
<% if (flash) { %><div class="flash flash-<%= flash.type %>"><div class="wrap"><%= flash.msg %></div></div><% } %>
<main class="wrap">
