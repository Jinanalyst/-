<%- include('partials/head') %>
<div class="auth-card">
  <h1>회원가입</h1>
  <p class="muted">자취마켓에 가입하고 가구·자취용품을 사고팔아 보세요.</p>
  <% if (error) { %><div class="form-error"><%= error %></div><% } %>
  <form method="post" action="/signup">
    <label>아이디 <span class="req">*</span>
      <input name="username" value="<%= form.username || '' %>" placeholder="영문/숫자 3~20자" required>
    </label>
    <label>이메일 <span class="req">*</span>
      <input type="email" name="email" value="<%= form.email || '' %>" placeholder="you@example.com" required>
    </label>
    <label>닉네임 <span class="req">*</span>
      <input name="nickname" value="<%= form.nickname || '' %>" placeholder="거래 시 표시될 이름" required>
    </label>
    <label>주 활동지역
      <input name="area" value="<%= form.area || '' %>" placeholder="예: 서울 관악구 신림동">
    </label>
    <label>비밀번호 <span class="req">*</span>
      <input type="password" name="password" placeholder="6자 이상" required>
    </label>
    <label>비밀번호 확인 <span class="req">*</span>
      <input type="password" name="password2" required>
    </label>
    <button class="btn btn-primary btn-block" type="submit">가입하기</button>
  </form>
  <p class="alt">이미 계정이 있으신가요? <a href="/login">로그인</a></p>
</div>
<%- include('partials/foot') %>
